# ============================================================================
# Variables de entorno - COOPCASA Web
# Copia este archivo como ".env" y completa los valores reales antes de
# integrar el backend. Ninguna de estas URLs debe apuntar a datos reales
# mientras el backend no esté implementado.
# ============================================================================

# Endpoint de autenticación (Oficina Virtual). Debe aceptar POST { usuario, password }
# y responder con un token/sesión. Reemplazar por el endpoint real del backend.
PUBLIC_API_LOGIN_URL=https://api.coopcasa.do/auth/login

# Endpoint para el formulario "Hazte Socio". Debe aceptar POST con los datos
# del formulario de afiliación. Reemplazar por el endpoint real del backend.
PUBLIC_API_MEMBERS_URL=https://api.coopcasa.do/members/apply
