---
import Icon from '@shared/ui/Icon.astro';
import { institutionalFacts, institutionalFactsSection } from '@data/about';
---

<section class="px-5 pt-4 pb-14 lg:px-8 lg:pb-16">
  <div
    class="mx-auto max-w-[1220px] rounded-[28px] border border-ink-900/8 bg-surface-50 p-7 sm:p-10"
  >
    <div class="mb-8 text-center">
      <div class="mb-2.5 text-[13px] font-bold tracking-[0.1em] text-brand-800 uppercase">
        {institutionalFactsSection.eyebrow}
      </div>
      <h2 class="text-2xl font-extrabold tracking-tight text-ink-900 sm:text-[28px]">
        {institutionalFactsSection.title}
      </h2>
    </div>
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-3">
      {
        institutionalFacts.map((fact) => (
          <div class="flex flex-col items-center gap-3.5 text-center sm:items-start sm:text-left">
            <div class="flex h-12 w-12 flex-none items-center justify-center rounded-2xl bg-brand-600/10">
              <Icon name={fact.icon} size={22} color="#1f8f22" />
            </div>
            <div>
              <div class="mb-1 text-[13px] font-bold tracking-[0.04em] text-brand-800 uppercase">
                {fact.label}
              </div>
              <p class="text-[15px] leading-relaxed text-body-500">{fact.value}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
