---
import Icon from '@shared/ui/Icon.astro';
import { institutionalFacts, institutionalFactsSection } from '@data/about';
---

<section class="px-5 pt-4 pb-14 lg:px-8 lg:pb-16">
  <div data-reveal="up" class="mx-auto max-w-[1220px]">
    <div class="mb-8 text-center">
      <div class="mb-2.5 text-[13px] font-bold tracking-[0.1em] text-brand-800 uppercase">
        {institutionalFactsSection.eyebrow}
      </div>
      <h2 class="text-2xl font-extrabold tracking-tight text-ink-900 sm:text-[28px]">
        {institutionalFactsSection.title}
      </h2>
    </div>
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-3">
      {
        institutionalFacts.map((fact, index) => (
          <div
            style={{ transitionDelay: `${index * 90}ms` }}
            class:list={[
              'flex flex-col items-center gap-3.5 rounded-[20px] border border-ink-900/8 bg-white p-6 text-center shadow-[0_4px_16px_rgba(13,31,20,0.05)] transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_18px_40px_rgba(13,31,20,0.1)] sm:items-start sm:text-left',
              index === 1 ? 'hover:border-gold-500/35' : 'hover:border-brand-600/25',
            ]}
          >
            <div
              class:list={[
                'flex h-12 w-12 flex-none items-center justify-center rounded-2xl',
                index === 1 ? 'bg-gold-400/22' : 'bg-brand-600/10',
              ]}
            >
              <Icon name={fact.icon} size={22} color={index === 1 ? '#a89a00' : '#1f8f22'} />
            </div>
            <div>
              <div
                class:list={[
                  'mb-1 text-[13px] font-bold tracking-[0.04em] uppercase',
                  index === 1 ? 'text-gold-800' : 'text-brand-800',
                ]}
              >
                {fact.label}
              </div>
              <p class="text-[15px] leading-relaxed text-body-500">{fact.value}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
