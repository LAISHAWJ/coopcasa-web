---
import { Image } from 'astro:assets';
import Icon from '@shared/ui/Icon.astro';
import { timeline } from '@data/about';
---

<section class="px-5 pt-16 pb-10 lg:px-8">
  <div class="relative mx-auto max-w-[980px]">
    <div
      class="pointer-events-none absolute top-2 bottom-2 left-[128px] hidden w-0.5 bg-[linear-gradient(180deg,#22a024,rgba(43,168,44,0.15))] sm:block"
    >
    </div>
    <div class="flex flex-col gap-10 sm:gap-14">
      {
        timeline.map((entry, index) => (
          <div
            data-reveal={index % 2 === 0 ? 'right' : 'left'}
            class="relative flex flex-col gap-3 sm:grid sm:grid-cols-[110px_1fr] sm:items-start sm:gap-9"
          >
            <div class="font-display text-xl font-extrabold tracking-tight text-brand-800 sm:pt-2 sm:text-right sm:text-[26px]">
              {entry.year}
            </div>
            <div class="relative">
              <span class="absolute top-0 z-10 -left-9 hidden h-9 w-9 items-center justify-center rounded-full border-[3px] border-white bg-[linear-gradient(135deg,#22a024,#2fb531)] shadow-[0_0_0_3px_rgba(43,168,44,0.2)] sm:flex">
                <Icon name={entry.icon} size={16} color="#fff" strokeWidth={2.2} />
              </span>

              {entry.image ? (
                <div class="grid overflow-hidden rounded-[22px] border border-ink-900/8 bg-white shadow-[0_4px_16px_rgba(13,31,20,0.05)] transition-all duration-300 hover:-translate-y-1 hover:border-brand-600/25 hover:shadow-[0_18px_40px_rgba(13,31,20,0.12)] sm:grid-cols-2">
                  <div class="h-[200px] sm:h-full sm:min-h-[220px]">
                    <Image
                      src={entry.image.src}
                      alt={entry.image.alt}
                      width={480}
                      height={360}
                      loading="lazy"
                      class="h-full w-full object-cover"
                    />
                  </div>
                  <div class="flex flex-col justify-center p-6">
                    <h3 class="mb-2 text-lg font-bold text-ink-900 sm:text-[19px]">{entry.title}</h3>
                    <p class="text-[14.5px] leading-relaxed text-body-400">{entry.description}</p>
                  </div>
                </div>
              ) : (
                <div class="rounded-[18px] border border-ink-900/8 bg-white p-6 shadow-[0_4px_16px_rgba(13,31,20,0.05)] transition-all duration-300 hover:-translate-y-1 hover:border-brand-600/25 hover:shadow-[0_14px_34px_rgba(13,31,20,0.1)]">
                  <h3 class="mb-2 text-lg font-bold text-ink-900 sm:text-[19px]">{entry.title}</h3>
                  <p class="text-[14.5px] leading-relaxed text-body-400">{entry.description}</p>
                </div>
              )}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
