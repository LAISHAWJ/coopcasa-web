---
import Icon from '@shared/ui/Icon.astro';
import { institutionalFacts, institutionalFactsSection } from '@data/about';
---

<!-- Ficha institucional: cierre fuerte y formal de la página, con tratamiento
     de documento/sello oficial, distinto de la banda de cifras (arriba,
     oscura y animada) y del resto de bloques narrativos. Cada dato vive en su
     propia mini-tarjeta con ícono, para una jerarquía clara entre el título
     de cierre y los datos legales. -->
<section class="relative overflow-hidden px-5 pt-14 pb-20 lg:px-8 lg:pt-20 lg:pb-28">
  <div
    aria-hidden="true"
    class="pointer-events-none absolute top-10 left-1/2 h-[460px] w-[460px] -translate-x-[70%] rounded-full bg-[radial-gradient(circle,rgba(43,168,44,0.16),transparent_65%)] blur-[6px]"
  >
  </div>
  <div
    aria-hidden="true"
    class="pointer-events-none absolute bottom-0 left-1/2 h-[380px] w-[380px] translate-x-[20%] rounded-full bg-[radial-gradient(circle,rgba(243,229,0,0.16),transparent_65%)] blur-[6px]"
  >
  </div>

  <div data-story-group class="relative z-[1] mx-auto max-w-[960px]">
    <div
      data-story="up"
      class="glass-light relative rounded-[32px] border-2 border-dashed border-brand-600/30 p-8 sm:p-12 lg:p-16"
    >
      <div
        class="absolute -top-10 right-8 flex h-[86px] w-[86px] flex-col items-center justify-center rounded-full bg-[linear-gradient(135deg,#22a024,#2fb531)] text-center shadow-[0_16px_34px_rgba(43,168,44,0.35)] ring-[6px] ring-white sm:right-12"
      >
        <Icon name="shield" size={24} color="#fff" />
        <span class="mt-1 px-1.5 text-[7.5px] leading-tight font-bold tracking-wide text-white uppercase">
          {institutionalFactsSection.stampLabel}
        </span>
      </div>

      <div class="mt-6 mb-10 text-center sm:mt-0 sm:text-left">
        <div class="mb-2 text-[13px] font-bold tracking-[0.14em] text-brand-800 uppercase">
          {institutionalFactsSection.eyebrow}
        </div>
        <h2 class="text-[30px] font-extrabold tracking-tight text-ink-900 sm:text-[38px] lg:text-[44px]">
          {institutionalFactsSection.title}
        </h2>
      </div>

      <dl class="grid grid-cols-1 gap-5 border-t border-ink-900/10 pt-10 sm:grid-cols-3 sm:gap-6">
        {
          institutionalFacts.map((fact) => (
            <div class="rounded-2xl border border-ink-900/8 bg-white/45 p-6">
              <dt class="mb-4 flex items-center gap-3">
                <span class="flex h-10 w-10 flex-none items-center justify-center rounded-full bg-brand-600/12">
                  <Icon name={fact.icon} size={18} color="#1f8f22" strokeWidth={2.2} />
                </span>
                <span class="text-[12px] font-bold tracking-wide text-brand-800 uppercase">
                  {fact.label}
                </span>
              </dt>
              <dd class="text-[15px] leading-relaxed text-ink-900">{fact.value}</dd>
            </div>
          ))
        }
      </dl>
    </div>
  </div>
</section>

<style>
  .glass-light {
    background: rgba(255, 255, 255, 0.55);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    box-shadow: 0 24px 60px rgba(13, 31, 20, 0.12);
  }
  @supports not ((backdrop-filter: blur(1px)) or (-webkit-backdrop-filter: blur(1px))) {
    .glass-light {
      background: rgba(255, 255, 255, 0.92);
    }
  }
</style>

<script>
  import { initScrollStory } from '@shared/utils/scrollStory';

  initScrollStory();
</script>
