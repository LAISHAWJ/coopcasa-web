---
import { stats } from '@data/stats';
import { historyStatsSection } from '@data/about';
import { formatStatValue } from '@shared/utils/formatNumber';
---

<section class="px-5 pt-8 pb-20 lg:px-8">
  <div
    class="relative mx-auto max-w-[1220px] overflow-hidden rounded-[32px] bg-[linear-gradient(135deg,#0d1f14,#14361b)] p-7 sm:p-10 lg:p-14"
  >
    <div
      class="pointer-events-none absolute -top-[100px] -right-10 h-[300px] w-[300px] rounded-full bg-[radial-gradient(circle,rgba(43,168,44,0.28),transparent_65%)] lg:h-[360px] lg:w-[360px]"
    >
    </div>
    <div class="relative z-[1] mx-auto mb-10 max-w-[560px] text-center">
      <h2 class="text-[26px] font-extrabold tracking-tight text-white sm:text-[32px]">
        {historyStatsSection.title}
      </h2>
    </div>
    <div class="relative z-[1] grid grid-cols-2 gap-4 lg:grid-cols-4 lg:gap-6">
      {
        stats.map((stat) => (
          <div class="rounded-[20px] border border-white/10 bg-white/6 px-5 py-7 text-center backdrop-blur-md">
            <div class="bg-[linear-gradient(120deg,#7ee05a,#f3e500)] bg-clip-text font-display text-[28px] leading-none font-extrabold tracking-tight text-transparent sm:text-[38px]">
              {formatStatValue(stat.target, {
                prefix: stat.prefix,
                suffix: stat.suffix,
                decimals: stat.decimals,
              })}
            </div>
            <div class="mt-2.5 text-[13px] font-medium text-white/72">{stat.label}</div>
          </div>
        ))
      }
    </div>
  </div>
</section>
