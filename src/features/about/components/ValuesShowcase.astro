---
import Icon from '@shared/ui/Icon.astro';
import { values, valuesSection } from '@data/about';
---

<section class="px-5 pt-12 pb-20 lg:px-8 lg:pb-[88px]">
  <div class="mx-auto max-w-[900px]">
    <div data-reveal="up" class="mx-auto mb-10 max-w-[560px] text-center">
      <div class="mb-3 text-[13px] font-bold tracking-[0.1em] text-brand-800 uppercase">
        {valuesSection.eyebrow}
      </div>
      <h2 class="text-[26px] font-extrabold tracking-tight text-ink-900 sm:text-[36px]">
        {valuesSection.title}
      </h2>
    </div>

    <!-- Lista tipográfica: cada valor es una fila grande de texto, no una tarjeta
         repetida. La alineación alterna izquierda/derecha entre filas. -->
    <div class="border-t border-ink-900/8">
      {
        values.map((value, index) => {
          const isReversed = index % 2 === 1;
          return (
            <div data-reveal="up" style={{ transitionDelay: `${(index % 3) * 80}ms` }}>
              <div
                tabindex="0"
                class:list={[
                  'group flex flex-col gap-3 border-b border-ink-900/8 py-7 transition-colors duration-300 hover:bg-surface-50 focus:bg-surface-50 focus:outline-none sm:flex-row sm:items-baseline sm:gap-8 sm:py-9',
                  isReversed ? 'sm:flex-row-reverse sm:text-right' : 'sm:text-left',
                ]}
              >
                <div
                  class:list={[
                    'flex items-center gap-4',
                    isReversed ? 'sm:flex-row-reverse' : '',
                  ]}
                >
                  <span
                    class:list={[
                      'flex h-11 w-11 flex-none items-center justify-center rounded-full transition-transform duration-300 group-hover:scale-110 group-focus:scale-110',
                      value.iconBg,
                    ]}
                  >
                    <Icon name={value.icon} size={20} color={value.iconColor} />
                  </span>
                  <h3 class="font-display text-[30px] leading-none font-extrabold tracking-tight text-ink-900 sm:text-[40px]">
                    {value.title}
                  </h3>
                </div>
                <p
                  class:list={[
                    'max-w-[380px] text-[15px] leading-relaxed text-body-400 sm:ml-auto',
                    isReversed && 'sm:mr-auto sm:ml-0',
                  ]}
                >
                  {value.description}
                </p>
              </div>
            </div>
          );
        })
      }
    </div>
  </div>
</section>
