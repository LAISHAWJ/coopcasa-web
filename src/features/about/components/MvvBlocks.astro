---
import Icon from '@shared/ui/Icon.astro';
import { mvvBlocks } from '@data/about';
---

<section class="px-5 pt-8 pb-5 lg:px-8">
  <div class="mx-auto flex max-w-[1080px] flex-col gap-6">
    {mvvBlocks.map((block) => (
      <div
        class="relative overflow-hidden rounded-[26px] border border-ink-900/8 p-7 shadow-[0_8px_30px_rgba(13,31,20,0.05)] sm:p-10"
        style={{ background: block.background }}
      >
        <div
          class:list={[
            'pointer-events-none absolute h-[220px] w-[220px] rounded-full bg-[radial-gradient(circle,rgba(43,168,44,0.16),transparent_65%)] sm:h-[280px] sm:w-[280px]',
            block.blobPosition === 'top-right' ? '-top-20 -right-14' : '-bottom-20 -left-14',
          ]}
        >
        </div>
        <div class="relative z-[1] grid grid-cols-1 items-center gap-6 sm:grid-cols-[100px_1fr] sm:gap-8">
          <div class:list={['flex h-[72px] w-[72px] items-center justify-center rounded-3xl sm:h-[88px] sm:w-[88px]', block.iconBg]}>
            <Icon name={block.icon} size={36} color={block.iconColor} strokeWidth={1.8} class="sm:h-10 sm:w-10" />
          </div>
          <div>
            <div class="mb-2.5 text-[13px] font-bold tracking-[0.1em] text-brand-800 uppercase">{block.tag}</div>
            <h2 class="mb-3 text-2xl font-extrabold tracking-tight text-ink-900 sm:text-[28px]">{block.title}</h2>
            <p class="text-[16.5px] leading-relaxed text-body-500">{block.text}</p>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>
