---
import { Image } from 'astro:assets';
import { missionContent, visionContent } from '@data/about';
---

<!-- Misión y Visión: un solo panel dividido en dos mitades (no cards separadas).
     El contraste claro/oscuro entre ambas ES la separación visual. Cada mitad
     lleva su contenido dentro de un panel "glass" (backdrop-blur) flotando
     sobre el fondo con tinte de la mitad, y una foto real en un marco normal
     (recuadro redondeado + sombra), sin recorte de fondo. En mobile, una
     franja de transición con degradado marca el quiebre entre ambas. -->
<section class="overflow-hidden">
  <div class="grid grid-cols-1 md:grid-cols-2">
    <!-- Misión: mitad clara. -->
    <div
      data-story-group
      class="relative flex min-h-[600px] flex-col justify-center overflow-hidden bg-[linear-gradient(160deg,#fbfdfb,#fff)] px-6 py-16 sm:px-10 lg:min-h-[680px] lg:px-14 lg:py-20"
    >
      <div
        aria-hidden="true"
        class="pointer-events-none absolute -top-24 -left-16 h-[320px] w-[320px] rounded-full bg-[radial-gradient(circle,rgba(43,168,44,0.16),transparent_65%)] blur-[6px]"
      >
      </div>
      <span
        aria-hidden="true"
        class="pointer-events-none absolute -top-6 -left-4 font-display text-[110px] leading-none font-extrabold text-brand-600/[0.07] select-none sm:text-[150px] lg:text-[190px]"
      >
        {missionContent.bigWord}
      </span>

      <div
        data-story="up"
        class="glass-light relative z-[1] mx-auto w-full max-w-[460px] rounded-[28px] p-7 sm:p-9 md:mx-0 md:mr-4 md:ml-auto lg:mr-8 lg:p-10"
      >
        <div class="mb-2.5 text-[13px] font-bold tracking-[0.1em] text-brand-800 uppercase">
          {missionContent.tag}
        </div>
        <h2 class="mb-4 text-2xl font-extrabold tracking-tight text-ink-900 sm:text-[30px]">
          {missionContent.title}
        </h2>
        <p class="mb-7 text-[15.5px] leading-relaxed text-body-500">
          {missionContent.text}
        </p>
        <div data-story="scale" class="photo-frame">
          <Image
            src={missionContent.image.src}
            alt={missionContent.image.alt}
            width={800}
            height={533}
            loading="lazy"
            class="aspect-[3/2] h-auto w-full rounded-2xl object-cover"
          />
        </div>
      </div>
    </div>

    <!-- Transición mobile: franja de degradado entre Misión y Visión (oculta en md+). -->
    <div aria-hidden="true" class="h-10 bg-[linear-gradient(180deg,#ffffff,#0d1f14)] md:hidden"></div>

    <!-- Visión: mitad oscura, contraste directo con Misión. -->
    <div
      data-story-group
      class="relative flex min-h-[600px] flex-col justify-center overflow-hidden bg-[linear-gradient(160deg,#0d1f14,#14361b)] px-6 py-16 sm:px-10 lg:min-h-[680px] lg:px-14 lg:py-20"
    >
      <span
        aria-hidden="true"
        class="pointer-events-none absolute -top-6 -right-4 font-display text-[110px] leading-none font-extrabold text-white/[0.05] select-none sm:text-[150px] lg:text-[190px]"
      >
        {visionContent.bigWord}
      </span>
      <div class="vision-glow pointer-events-none absolute top-1/3 right-0 h-[320px] w-[320px] translate-x-1/3 rounded-full bg-[radial-gradient(circle,rgba(243,229,0,0.18),transparent_68%)]">
      </div>

      <div
        data-story="up"
        class="glass-dark relative z-[1] mx-auto w-full max-w-[460px] rounded-[28px] p-7 sm:p-9 md:mr-auto md:ml-4 lg:ml-8 lg:p-10"
      >
        <div class="mb-2.5 text-[13px] font-bold tracking-[0.1em] text-gold-400 uppercase">
          {visionContent.tag}
        </div>
        <h2 class="mb-4 text-2xl font-extrabold tracking-tight text-white sm:text-[30px]">
          {visionContent.title}
        </h2>
        <p class="mb-7 text-[15.5px] leading-relaxed text-white/75">
          {visionContent.text}
        </p>
        <div data-story="scale" class="photo-frame">
          <Image
            src={visionContent.image.src}
            alt={visionContent.image.alt}
            width={800}
            height={533}
            loading="lazy"
            class="aspect-[3/2] h-auto w-full rounded-2xl object-cover"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Glass claro: vidrio esmerilado blanco sobre el fondo con tinte de color
     de la mitad. Fallback sólido para navegadores sin backdrop-filter. */
  .glass-light {
    background: rgba(255, 255, 255, 0.55);
    border: 1px solid rgba(255, 255, 255, 0.6);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    box-shadow: 0 20px 50px rgba(13, 31, 20, 0.1);
  }
  @supports not ((backdrop-filter: blur(1px)) or (-webkit-backdrop-filter: blur(1px))) {
    .glass-light {
      background: rgba(255, 255, 255, 0.92);
    }
  }

  /* Glass oscuro: vidrio sutil sobre el verde institucional de Visión. */
  .glass-dark {
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.12);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.35);
  }
  @supports not ((backdrop-filter: blur(1px)) or (-webkit-backdrop-filter: blur(1px))) {
    .glass-dark {
      background: rgba(13, 31, 20, 0.82);
    }
  }

  /* Foto en marco normal: sombra realista calibrada (no la sombra plana por
     defecto de Tailwind), sin recorte de fondo ni flotación continua. */
  .photo-frame :global(img) {
    box-shadow:
      0 4px 10px rgba(13, 31, 20, 0.12),
      0 16px 32px rgba(13, 31, 20, 0.16);
  }

  @media (prefers-reduced-motion: no-preference) {
    .vision-glow {
      animation: vision-breathe 6s ease-in-out infinite;
    }
  }
  @keyframes vision-breathe {
    0%,
    100% {
      opacity: 0.7;
      transform: scale(1);
    }
    50% {
      opacity: 1;
      transform: scale(1.08);
    }
  }
</style>

<script>
  import { initScrollStory } from '@shared/utils/scrollStory';

  initScrollStory();
</script>
