---
import { Image } from 'astro:assets';
import { missionContent, visionContent } from '@data/about';
---

<!-- Misión y Visión: un solo panel dividido en dos mitades (no cards separadas).
     El contraste claro/oscuro entre ambas ES la separación visual. -->
<section class="overflow-hidden">
  <div class="grid grid-cols-1 md:grid-cols-2">
    <!-- Misión: mitad clara. -->
    <div
      data-story-group
      class="relative flex min-h-[600px] flex-col justify-center overflow-hidden bg-[linear-gradient(160deg,#fbfdfb,#fff)] px-6 py-16 sm:px-10 lg:min-h-[680px] lg:px-14 lg:py-20"
    >
      <span
        aria-hidden="true"
        class="pointer-events-none absolute -top-6 -left-4 font-display text-[110px] leading-none font-extrabold text-brand-600/[0.07] select-none sm:text-[150px] lg:text-[190px]"
      >
        {missionContent.bigWord}
      </span>

      <div class="relative z-[1] mx-auto w-full max-w-[440px] md:mx-0 md:ml-auto md:mr-4 lg:mr-8">
        <div data-story="up" class="mb-2.5 text-[13px] font-bold tracking-[0.1em] text-brand-800 uppercase">
          {missionContent.tag}
        </div>
        <h2 data-story="up" class="mb-4 text-2xl font-extrabold tracking-tight text-ink-900 sm:text-[30px]">
          {missionContent.title}
        </h2>
        <p data-story="up" class="mb-8 text-[15.5px] leading-relaxed text-body-500">
          {missionContent.text}
        </p>
        <div data-story="scale" class="float-soft flex justify-center">
          <Image
            src={missionContent.image.src}
            alt={missionContent.image.alt}
            width={420}
            height={438}
            loading="lazy"
            class="drop-shadow-brand h-auto w-[240px] sm:w-[280px]"
          />
        </div>
      </div>
    </div>

    <!-- Visión: mitad oscura, contraste directo con Misión. -->
    <div
      data-story-group
      class="relative flex min-h-[600px] flex-col justify-center overflow-hidden bg-[linear-gradient(160deg,#0d1f14,#14361b)] px-6 py-16 sm:px-10 lg:min-h-[680px] lg:px-14 lg:py-20"
    >
      <span
        aria-hidden="true"
        class="pointer-events-none absolute -top-6 -right-4 font-display text-[110px] leading-none font-extrabold text-white/[0.05] select-none sm:text-[150px] lg:text-[190px]"
      >
        {visionContent.bigWord}
      </span>
      <div class="vision-glow pointer-events-none absolute top-1/3 right-0 h-[320px] w-[320px] translate-x-1/3 rounded-full bg-[radial-gradient(circle,rgba(243,229,0,0.18),transparent_68%)]">
      </div>

      <div class="relative z-[1] mx-auto w-full max-w-[440px] md:mx-0 md:mr-auto md:ml-4 lg:ml-8">
        <div data-story="up" class="mb-2.5 text-[13px] font-bold tracking-[0.1em] text-gold-400 uppercase">
          {visionContent.tag}
        </div>
        <h2 data-story="up" class="mb-4 text-2xl font-extrabold tracking-tight text-white sm:text-[30px]">
          {visionContent.title}
        </h2>
        <p data-story="up" class="mb-8 text-[15.5px] leading-relaxed text-white/75">
          {visionContent.text}
        </p>
        <div data-story="scale" class="float-soft float-soft--delayed flex justify-center">
          <Image
            src={visionContent.image.src}
            alt={visionContent.image.alt}
            width={420}
            height={422}
            loading="lazy"
            class="drop-shadow-gold h-auto w-[240px] sm:w-[280px]"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Sombra suave que sigue el contorno real de la ilustración (canal alpha),
     no una sombra rectangular. Dos capas: una ajustada y una más difusa. */
  .drop-shadow-brand {
    filter:
      drop-shadow(0 8px 10px rgba(13, 31, 20, 0.18))
      drop-shadow(0 22px 30px rgba(43, 168, 44, 0.16));
  }
  .drop-shadow-gold {
    filter:
      drop-shadow(0 8px 10px rgba(0, 0, 0, 0.3))
      drop-shadow(0 22px 30px rgba(243, 229, 0, 0.14));
  }

  /* Flotación continua sutil, reforzando que la imagen no tiene marco/fondo. */
  @media (prefers-reduced-motion: no-preference) {
    .float-soft {
      animation: mvv-float 6s ease-in-out infinite;
    }
    .float-soft--delayed {
      animation-delay: 1.4s;
    }
    .vision-glow {
      animation: vision-breathe 6s ease-in-out infinite;
    }
  }
  @keyframes mvv-float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-14px);
    }
  }
  @keyframes vision-breathe {
    0%,
    100% {
      opacity: 0.7;
      transform: scale(1);
    }
    50% {
      opacity: 1;
      transform: scale(1.08);
    }
  }
</style>

<script>
  import { initScrollStory } from '@shared/utils/scrollStory';

  initScrollStory();
</script>
