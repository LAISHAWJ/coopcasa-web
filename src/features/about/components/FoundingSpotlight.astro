---
import { Image } from 'astro:assets';
import { foundingStory } from '@data/about';
import { hexToRgba } from '@shared/utils/color';

const accentGlow = hexToRgba(foundingStory.accentColor, 0.16);
---

<section class="relative overflow-hidden bg-white px-5 py-20 lg:px-8 lg:py-28">
  <!-- Tipografía expresiva de fondo: el año de fundación como elemento gráfico,
       teñido con el acento "antiguo" que abre la progresión cronológica. -->
  <span
    aria-hidden="true"
    style={{ color: foundingStory.accentColor, opacity: 0.08 }}
    class="pointer-events-none absolute -top-10 -left-6 font-display text-[150px] leading-none font-extrabold select-none sm:text-[220px] lg:-top-16 lg:text-[300px]"
  >
    {foundingStory.yearLabel}
  </span>
  <!-- Mancha de color decorativa: da contraste detrás del panel glass. -->
  <div
    aria-hidden="true"
    style={{ background: `radial-gradient(circle, ${accentGlow}, transparent 65%)` }}
    class="pointer-events-none absolute top-1/2 left-1/2 h-[520px] w-[520px] -translate-x-1/2 -translate-y-1/2 rounded-full blur-[6px]"
  >
  </div>

  <div
    data-story-group
    class="glass-light relative z-[1] mx-auto grid max-w-[1180px] items-center gap-14 rounded-[28px] p-8 sm:p-10 lg:grid-cols-[1.1fr_0.9fr] lg:gap-10 lg:p-14"
  >
    <div data-story="right" class="lg:order-2 lg:pl-6">
      <div
        style={{ color: foundingStory.accentColor }}
        class="mb-3.5 text-[13px] font-bold tracking-[0.1em] uppercase"
      >
        {foundingStory.eyebrow}
      </div>
      <h2
        class="mb-5 text-[34px] leading-[1.1] font-extrabold tracking-tight text-ink-900 sm:text-[44px]"
      >
        {foundingStory.title}
      </h2>
      <p class="max-w-[480px] text-lg leading-[1.75] text-body-500">
        {foundingStory.text}
      </p>
    </div>

    <div data-story="left" class="relative mx-auto w-full max-w-[440px] lg:order-1 lg:mx-0">
      <div data-story="scale" class="photo-frame">
        <Image
          src={foundingStory.image.src}
          alt={foundingStory.image.alt}
          width={880}
          height={495}
          loading="lazy"
          class="aspect-[16/9] h-auto w-full rounded-2xl object-cover"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .glass-light {
    background: rgba(255, 255, 255, 0.55);
    border: 1px solid rgba(255, 255, 255, 0.6);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    box-shadow: 0 20px 50px rgba(13, 31, 20, 0.1);
  }
  @supports not ((backdrop-filter: blur(1px)) or (-webkit-backdrop-filter: blur(1px))) {
    .glass-light {
      background: rgba(255, 255, 255, 0.92);
    }
  }

  .photo-frame :global(img) {
    box-shadow:
      0 10px 14px rgba(13, 31, 20, 0.14),
      0 24px 40px rgba(13, 31, 20, 0.14);
  }
</style>

<script>
  import { initScrollStory } from '@shared/utils/scrollStory';

  initScrollStory();
</script>
