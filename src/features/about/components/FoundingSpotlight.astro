---
import { Image } from 'astro:assets';
import { foundingStory } from '@data/about';
---

<section class="relative overflow-hidden bg-white px-5 py-20 lg:px-8 lg:py-28">
  <!-- Tipografía expresiva de fondo: el año de fundación como elemento gráfico,
       no como dato aislado. aria-hidden porque el año ya está en el texto. -->
  <span
    aria-hidden="true"
    class="pointer-events-none absolute -top-10 -left-6 font-display text-[150px] leading-none font-extrabold text-brand-600/8 select-none sm:text-[220px] lg:-top-16 lg:text-[300px]"
  >
    {foundingStory.yearLabel}
  </span>

  <div
    class="relative z-[1] mx-auto grid max-w-[1180px] items-center gap-14 lg:grid-cols-[1.15fr_0.85fr] lg:gap-10"
  >
    <div data-reveal="right" class="lg:order-2 lg:pl-6">
      <div class="mb-3.5 text-[13px] font-bold tracking-[0.1em] text-brand-800 uppercase">
        {foundingStory.eyebrow}
      </div>
      <h2
        class="mb-5 text-[34px] leading-[1.1] font-extrabold tracking-tight text-ink-900 sm:text-[44px]"
      >
        {foundingStory.title}
      </h2>
      <p class="max-w-[480px] text-lg leading-[1.75] text-body-500">
        {foundingStory.text}
      </p>
    </div>

    <div data-reveal="left" class="relative lg:order-1">
      <div
        class="relative mx-auto max-w-[380px] -rotate-2 overflow-hidden rounded-[26px] shadow-[0_30px_60px_rgba(13,31,20,0.2)] transition-transform duration-500 hover:rotate-0 lg:mx-0 lg:ml-10"
      >
        <Image
          src={foundingStory.image.src}
          alt={foundingStory.image.alt}
          width={560}
          height={640}
          loading="lazy"
          class="h-[340px] w-full object-cover sm:h-[420px]"
        />
      </div>
    </div>
  </div>
</section>
