---
import Icon from '@shared/ui/Icon.astro';
import { values, valuesSection } from '@data/about';
---

<section class="px-5 pt-12 pb-20 lg:px-8 lg:pb-[88px]">
  <div class="mx-auto max-w-[1220px]">
    <div class="mx-auto mb-11 max-w-[560px] text-center">
      <div class="mb-3 text-[13px] font-bold tracking-[0.1em] text-brand-800 uppercase">
        {valuesSection.eyebrow}
      </div>
      <h2 class="text-[26px] font-extrabold tracking-tight text-ink-900 sm:text-[36px]">
        {valuesSection.title}
      </h2>
    </div>

    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        values.map((value) => (
          <div class="rounded-[20px] border border-ink-900/8 bg-white p-[26px] transition-all duration-300 hover:-translate-y-1.5 hover:border-brand-600/30 hover:shadow-[0_18px_44px_rgba(13,31,20,0.1)]">
            <div
              class:list={[
                'mb-[18px] flex h-[50px] w-[50px] items-center justify-center rounded-2xl',
                value.iconBg,
              ]}
            >
              <Icon name={value.icon} size={24} color={value.iconColor} />
            </div>
            <h3 class="mb-2 text-lg font-bold text-ink-900">{value.title}</h3>
            <p class="text-sm leading-relaxed text-body-400">{value.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
