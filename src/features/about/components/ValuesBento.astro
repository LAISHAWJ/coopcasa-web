---
import { Image } from 'astro:assets';
import { values, valuesSection } from '@data/about';

const AREAS = ['a', 'b', 'c', 'd', 'e', 'f'];
---

<!-- Valores: tratamiento propio y diferenciado del panel Misión/Visión de
     arriba. En vez de iconos genéricos, cada valor se apoya en tipografía
     grande (numeración) y color de acento como elementos protagonistas; el
     único apoyo fotográfico es un recorte de detalle (manos estrechándose)
     junto al encabezado, no un ícono plano. -->
<section class="relative overflow-hidden bg-surface-50 px-5 pt-16 pb-20 lg:px-8 lg:pb-28">
  <div class="mx-auto max-w-[1100px]">
    <div
      data-story-group
      class="relative mb-12 flex flex-col items-center gap-6 text-center sm:flex-row sm:justify-between sm:text-left"
    >
      <div data-story="up" class="max-w-[480px]">
        <div class="mb-3 text-[13px] font-bold tracking-[0.1em] text-brand-800 uppercase">
          {valuesSection.eyebrow}
        </div>
        <h2 class="text-[26px] font-extrabold tracking-tight text-ink-900 sm:text-[36px]">
          {valuesSection.title}
        </h2>
      </div>
      <div data-story="scale" class="values-float flex-none">
        <Image
          src={valuesSection.image.src}
          alt={valuesSection.image.alt}
          width={300}
          height={200}
          loading="lazy"
          class="drop-shadow-values h-auto w-[150px] rounded-2xl sm:w-[190px]"
        />
      </div>
    </div>

    <!-- Mosaico asimétrico (no cards idénticas): un bloque grande + cinco de
         distinto tamaño. Cada celda lleva su número de orden en tipografía
         grande y el color de acento como protagonista, en vez de un ícono. -->
    <div data-story-group class="values-bento">
      {
        values.map((value, index) => (
          <div data-story="scale" class={`values-bento__cell values-bento__cell--${AREAS[index]}`}>
            <div
              tabindex="0"
              class:list={[
                'group relative flex h-full flex-col justify-end gap-3 overflow-hidden rounded-[22px] p-6 transition-all duration-300 hover:-translate-y-1 hover:bg-white/70 hover:shadow-[0_20px_44px_rgba(13,31,20,0.1)] focus:-translate-y-1 focus:bg-white/70 focus:shadow-[0_20px_44px_rgba(13,31,20,0.1)] focus:outline-none',
                index === 0 ? 'sm:p-8' : '',
              ]}
            >
              <span
                aria-hidden="true"
                style={{ color: value.accentColor }}
                class:list={[
                  'pointer-events-none absolute -top-2 -right-1 font-display font-extrabold opacity-[0.12] transition-transform duration-300 select-none group-hover:scale-110 group-focus:scale-110',
                  index === 0 ? 'text-[110px] sm:text-[140px]' : 'text-[80px]',
                ]}
              >
                {String(index + 1).padStart(2, '0')}
              </span>
              <div
                style={{ background: value.accentColor }}
                class="h-1 w-10 flex-none rounded-full"
              />
              <div>
                <h3
                  class:list={[
                    'font-display font-extrabold tracking-tight text-ink-900',
                    index === 0 ? 'text-[28px] sm:text-[34px]' : 'text-xl sm:text-2xl',
                  ]}
                >
                  {value.title}
                </h3>
                <div class="values-bento__desc">
                  <p class="overflow-hidden pt-2 text-[14px] leading-relaxed text-body-400">
                    {value.description}
                  </p>
                </div>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .drop-shadow-values {
    filter:
      drop-shadow(0 6px 8px rgba(13, 31, 20, 0.12))
      drop-shadow(0 16px 24px rgba(43, 168, 44, 0.14));
  }

  @media (prefers-reduced-motion: no-preference) {
    .values-float {
      animation: values-float 5.5s ease-in-out infinite;
    }
  }
  @keyframes values-float {
    0%,
    100% {
      transform: translateY(0) rotate(-2deg);
    }
    50% {
      transform: translateY(-10px) rotate(2deg);
    }
  }

  .values-bento {
    display: grid;
    gap: 1.1rem;
    grid-template-columns: 1fr;
    grid-template-areas:
      'a'
      'b'
      'c'
      'd'
      'e'
      'f';
  }
  .values-bento__cell {
    min-height: 168px;
  }
  .values-bento__cell--a {
    grid-area: a;
  }
  .values-bento__cell--b {
    grid-area: b;
  }
  .values-bento__cell--c {
    grid-area: c;
  }
  .values-bento__cell--d {
    grid-area: d;
  }
  .values-bento__cell--e {
    grid-area: e;
  }
  .values-bento__cell--f {
    grid-area: f;
  }

  @media (min-width: 640px) {
    .values-bento {
      grid-template-columns: repeat(2, 1fr);
      grid-template-areas:
        'a a'
        'b c'
        'd e'
        'f f';
    }
  }

  @media (min-width: 1024px) {
    .values-bento {
      grid-template-columns: repeat(4, 1fr);
      grid-auto-rows: 172px;
      grid-template-areas:
        'a a b b'
        'a a c d'
        'e e f f';
    }
    .values-bento__cell--a {
      min-height: unset;
    }
  }

  /* La descripción queda visible por defecto (incluye táctil); solo se
     colapsa y revela con hover/foco en dispositivos con mouse real. */
  @media (hover: hover) and (pointer: fine) {
    .values-bento__desc {
      display: grid;
      grid-template-rows: 0fr;
      transition: grid-template-rows 0.3s ease-out;
    }
    .group:hover .values-bento__desc,
    .group:focus .values-bento__desc {
      grid-template-rows: 1fr;
    }
  }
</style>

<script>
  import { initScrollStory } from '@shared/utils/scrollStory';

  initScrollStory();
</script>
