---
import { Image } from 'astro:assets';
import Icon from '@shared/ui/Icon.astro';
import { growthChapters } from '@data/about';
import { hexToRgba } from '@shared/utils/color';
---

<!--
  Capítulos de crecimiento: cada uno es un bloque editorial con su propia
  ilustración flotante (sin marco, sombra de contorno) y su propio acento de
  color. El acento progresa del más apagado al verde de marca pleno, y el
  lado de la imagen se alterna, dando sensación de avance sin timeline ni
  cards repetidas.
-->
<section aria-label="Capítulos de crecimiento de COOPCASA">
  {
    growthChapters.map((chapter, index) => {
      const isReversed = index % 2 === 1;
      const wash = hexToRgba(chapter.accentColor, 0.06);
      const shadow = hexToRgba(chapter.accentColor, 0.3);
      return (
        <div
          class="overflow-hidden px-5 py-20 lg:px-8 lg:py-28"
          style={{ background: `linear-gradient(180deg, #fff, ${wash})` }}
        >
          <div
            data-story-group
            class:list={[
              'mx-auto grid max-w-[1180px] items-center gap-14 lg:gap-12',
              isReversed ? 'lg:grid-cols-[1.05fr_1fr]' : 'lg:grid-cols-[1fr_1.05fr]',
            ]}
          >
            <div
              class:list={[
                'relative mx-auto w-full max-w-[400px] lg:mx-0',
                isReversed ? 'order-first lg:order-2' : 'lg:order-1',
              ]}
            >
              <div
                data-story={isReversed ? 'right' : 'left'}
                class="chapter-float flex justify-center"
                style={{ '--chapter-shadow': shadow }}
              >
                <Image
                  src={chapter.image.src}
                  alt={chapter.image.alt}
                  width={480}
                  height={270}
                  loading="lazy"
                  class="chapter-drop-shadow h-auto w-full"
                />
              </div>
            </div>

            <div class:list={['relative', isReversed ? 'lg:order-1 lg:pr-6' : 'lg:order-2 lg:pl-6']}>
              <div
                data-story="up"
                style={{ color: chapter.accentColor }}
                class="mb-3.5 flex items-center gap-2.5 font-display text-sm font-bold tracking-[0.1em] uppercase"
              >
                <Icon name={chapter.icon} size={18} color={chapter.accentColor} strokeWidth={2.2} />
                {chapter.yearLabel}
              </div>
              <h2
                data-story="up"
                class="mb-4 text-[28px] leading-[1.1] font-extrabold tracking-tight text-ink-900 sm:text-[36px]"
              >
                {chapter.title}
              </h2>
              <p data-story="up" class="max-w-[460px] text-lg leading-[1.7] text-body-500">
                {chapter.description}
              </p>
            </div>
          </div>
        </div>
      );
    })
  }
</section>

<style>
  .chapter-drop-shadow {
    filter:
      drop-shadow(0 10px 14px rgba(13, 31, 20, 0.14))
      drop-shadow(0 24px 36px var(--chapter-shadow));
  }
  @media (prefers-reduced-motion: no-preference) {
    .chapter-float {
      animation: chapter-float 6s ease-in-out infinite;
    }
  }
  @keyframes chapter-float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-12px);
    }
  }
</style>

<script>
  import { initScrollStory } from '@shared/utils/scrollStory';

  initScrollStory();
</script>
