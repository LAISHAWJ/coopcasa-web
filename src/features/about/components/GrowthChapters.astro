---
import { Image } from 'astro:assets';
import Icon from '@shared/ui/Icon.astro';
import { growthChapters } from '@data/about';
import { hexToRgba } from '@shared/utils/color';
---

<!--
  Capítulos de crecimiento: cada uno es un bloque editorial con su propio
  acento de color y una foto real en marco normal (recuadro + sombra
  calibrada), dentro de un panel glass que flota sobre el degradado con tinte
  del capítulo. El acento progresa del más apagado al verde de marca pleno, y
  el lado de la imagen se alterna, dando sensación de avance sin timeline ni
  cards repetidas.
-->
<section aria-label="Capítulos de crecimiento de COOPCASA">
  {
    growthChapters.map((chapter, index) => {
      const isReversed = index % 2 === 1;
      const wash = hexToRgba(chapter.accentColor, 0.1);
      const shadow = hexToRgba(chapter.accentColor, 0.24);
      return (
        <div
          class="overflow-hidden px-5 py-20 lg:px-8 lg:py-28"
          style={{ background: `linear-gradient(180deg, #fff, ${wash})` }}
        >
          <div
            data-story-group
            style={{ '--chapter-shadow': shadow }}
            class:list={[
              'glass-light mx-auto grid max-w-[1180px] items-center gap-14 rounded-[28px] p-8 sm:p-10 lg:gap-12 lg:p-14',
              isReversed ? 'lg:grid-cols-[1.05fr_1fr]' : 'lg:grid-cols-[1fr_1.05fr]',
            ]}
          >
            <div
              class:list={[
                'relative mx-auto w-full max-w-[420px] lg:mx-0',
                isReversed ? 'order-first lg:order-2' : 'lg:order-1',
              ]}
            >
              <div data-story={isReversed ? 'right' : 'left'} class="photo-frame flex justify-center">
                <Image
                  src={chapter.image.src}
                  alt={chapter.image.alt}
                  width={840}
                  height={473}
                  loading="lazy"
                  class="aspect-[16/9] h-auto w-full rounded-2xl object-cover"
                />
              </div>
            </div>

            <div class:list={['relative', isReversed ? 'lg:order-1 lg:pr-6' : 'lg:order-2 lg:pl-6']}>
              <div
                data-story="up"
                style={{ color: chapter.accentColor }}
                class="mb-3.5 flex items-center gap-2.5 font-display text-sm font-bold tracking-[0.1em] uppercase"
              >
                <Icon name={chapter.icon} size={18} color={chapter.accentColor} strokeWidth={2.2} />
                {chapter.yearLabel}
              </div>
              <h2
                data-story="up"
                class="mb-4 text-[28px] leading-[1.1] font-extrabold tracking-tight text-ink-900 sm:text-[36px]"
              >
                {chapter.title}
              </h2>
              <p data-story="up" class="max-w-[460px] text-lg leading-[1.7] text-body-500">
                {chapter.description}
              </p>
            </div>
          </div>
        </div>
      );
    })
  }
</section>

<style>
  .glass-light {
    background: rgba(255, 255, 255, 0.55);
    border: 1px solid rgba(255, 255, 255, 0.6);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    box-shadow: 0 20px 50px rgba(13, 31, 20, 0.1);
  }
  @supports not ((backdrop-filter: blur(1px)) or (-webkit-backdrop-filter: blur(1px))) {
    .glass-light {
      background: rgba(255, 255, 255, 0.92);
    }
  }

  .photo-frame :global(img) {
    box-shadow:
      0 10px 14px rgba(13, 31, 20, 0.14),
      0 24px 36px var(--chapter-shadow);
  }
</style>

<script>
  import { initScrollStory } from '@shared/utils/scrollStory';

  initScrollStory();
</script>
