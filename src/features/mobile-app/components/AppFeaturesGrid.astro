---
import { Image } from 'astro:assets';
import { appFeatureBlocks, appFeaturesSection } from '@data/mobileApp';
---

<!-- Bloques de funcionalidades: en vez de un grid de 9 tarjetas de solo texto,
     se agrupan en 4 bloques editoriales alternados (texto + foto real), cada
     uno con bullets cortos en vez de párrafos largos, para que la página se
     lea rápido y liviana. Mismo panel glass usado en Historia/MVV. -->
<section class="relative overflow-hidden px-5 py-16 lg:px-8 lg:py-20">
  <div
    aria-hidden="true"
    class="pointer-events-none absolute -top-20 -right-20 h-[360px] w-[360px] rounded-full bg-[radial-gradient(circle,rgba(43,168,44,0.14),transparent_65%)] blur-[6px]"
  >
  </div>
  <div
    aria-hidden="true"
    class="pointer-events-none absolute top-1/2 -left-24 h-[320px] w-[320px] rounded-full bg-[radial-gradient(circle,rgba(243,229,0,0.12),transparent_65%)] blur-[6px]"
  >
  </div>
  <div class="relative z-[1] mx-auto max-w-[1220px]">
    <div class="mx-auto mb-14 max-w-[640px] text-center lg:mb-16">
      <div class="mb-3.5 text-[13px] font-bold tracking-[0.1em] text-brand-800 uppercase">
        {appFeaturesSection.eyebrow}
      </div>
      <h2 class="mb-3.5 text-[28px] font-extrabold tracking-tight text-ink-900 sm:text-[40px]">
        {appFeaturesSection.title}
      </h2>
      <p class="text-[17px] leading-relaxed text-body-500">{appFeaturesSection.description}</p>
    </div>

    <div class="flex flex-col gap-10 lg:gap-14">
      {
        appFeatureBlocks.map((block, index) => {
          const isReversed = index % 2 === 1;
          return (
            <div
              data-story-group
              class="glass-light rounded-[28px] p-7 sm:p-10 lg:p-12"
            >
              <div
                class:list={[
                  'grid items-center gap-10 lg:gap-12',
                  isReversed ? 'lg:grid-cols-[1fr_1.05fr]' : 'lg:grid-cols-[1.05fr_1fr]',
                ]}
              >
                <div
                  class:list={[
                    'relative mx-auto w-full max-w-[440px] lg:mx-0',
                    isReversed ? 'order-first lg:order-2' : 'lg:order-1',
                  ]}
                >
                  <div data-story={isReversed ? 'right' : 'left'} class="photo-frame">
                    <Image
                      src={block.image.src}
                      alt={block.image.alt}
                      width={840}
                      height={473}
                      loading="lazy"
                      class="aspect-[16/9] h-auto w-full rounded-2xl object-cover"
                    />
                  </div>
                </div>

                <div class:list={[isReversed ? 'lg:order-1 lg:pr-6' : 'lg:order-2 lg:pl-6']}>
                  <div
                    data-story="up"
                    class="mb-2.5 text-[13px] font-bold tracking-[0.1em] text-brand-800 uppercase"
                  >
                    {block.eyebrow}
                  </div>
                  <h3
                    data-story="up"
                    class="mb-5 text-2xl font-extrabold tracking-tight text-ink-900 sm:text-[28px]"
                  >
                    {block.title}
                  </h3>
                  <ul data-story="up" class="space-y-3">
                    {block.bullets.map((bullet) => (
                      <li class="flex items-start gap-2.5 text-[15px] leading-relaxed text-body-500">
                        <span class="mt-2 h-1.5 w-1.5 flex-none rounded-full bg-brand-600" />
                        {bullet}
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </div>
          );
        })
      }
    </div>
  </div>
</section>

<style>
  .glass-light {
    background: rgba(255, 255, 255, 0.55);
    border: 1px solid rgba(255, 255, 255, 0.6);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    box-shadow: 0 20px 50px rgba(13, 31, 20, 0.08);
  }
  @supports not ((backdrop-filter: blur(1px)) or (-webkit-backdrop-filter: blur(1px))) {
    .glass-light {
      background: rgba(255, 255, 255, 0.92);
    }
  }

  .photo-frame :global(img) {
    box-shadow:
      0 10px 14px rgba(13, 31, 20, 0.12),
      0 24px 36px rgba(13, 31, 20, 0.14);
  }
</style>

<script>
  import { initScrollStory } from '@shared/utils/scrollStory';

  initScrollStory();
</script>
