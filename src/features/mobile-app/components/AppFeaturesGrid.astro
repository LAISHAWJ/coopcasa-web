---
import Icon from '@shared/ui/Icon.astro';
import { appFeatures, appFeaturesSection } from '@data/mobileApp';
---

<section class="px-5 py-16 lg:px-8 lg:py-20">
  <div class="mx-auto max-w-[1220px]">
    <div class="mx-auto mb-12 max-w-[640px] text-center lg:mb-[52px]">
      <div class="mb-3.5 text-[13px] font-bold tracking-[0.1em] text-brand-800 uppercase">
        {appFeaturesSection.eyebrow}
      </div>
      <h2 class="mb-3.5 text-[28px] font-extrabold tracking-tight text-ink-900 sm:text-[40px]">
        {appFeaturesSection.title}
      </h2>
      <p class="text-[17px] leading-relaxed text-body-500">{appFeaturesSection.description}</p>
    </div>

    <div class="grid grid-cols-1 gap-[22px] sm:grid-cols-2 lg:grid-cols-3">
      {
        appFeatures.map((feature) => (
          <div class="rounded-[22px] border border-ink-900/8 bg-white p-[26px] shadow-[0_2px_10px_rgba(13,31,20,0.04)] transition-all duration-300 hover:-translate-y-1.5 hover:border-brand-600/30 hover:shadow-[0_20px_46px_rgba(13,31,20,0.1)] sm:p-[30px]">
            <div
              class:list={[
                'mb-5 flex h-[52px] w-[52px] items-center justify-center rounded-2xl',
                feature.iconBg,
              ]}
            >
              <Icon name={feature.icon} size={26} color={feature.iconColor} />
            </div>
            <h3 class="mb-2.5 text-lg font-bold text-ink-900 sm:text-[19px]">{feature.title}</h3>
            <p class="text-[14.5px] leading-relaxed text-body-400">{feature.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
