---
import Icon from '@shared/ui/Icon.astro';
import type { IconName } from '@shared/config/icons';

interface Props {
  href: string;
  icon: IconName;
  iconColor: string;
  storeLabel: string;
  storeName: string;
  /** 'light' = insignia blanca (hero), 'dark' = insignia oscura (CTA final). */
  tone?: 'light' | 'dark';
}

const { href, icon, iconColor, storeLabel, storeName, tone = 'light' } = Astro.props;
---

<a
  href={href}
  class:list={[
    'flex items-center gap-[11px] rounded-2xl px-[22px] py-[13px] transition-transform duration-200 hover:-translate-y-0.5',
    tone === 'light' ? 'bg-white text-ink-900' : 'bg-ink-900 text-white',
  ]}
>
  <Icon name={icon} variant="fill" color={iconColor} size={24} />
  <div class="text-left">
    <div class="text-[10px] opacity-70">{storeLabel}</div>
    <div class="font-display text-[15px] font-bold">{storeName}</div>
  </div>
</a>
