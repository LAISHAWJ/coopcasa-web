---
import { Image } from 'astro:assets';
import logo from '@assets/images/coopcasa-logo.png';
import Button from '@shared/ui/Button.astro';
import Icon from '@shared/ui/Icon.astro';
import StoreBadgeLink from './StoreBadgeLink.astro';
import { mobileAppHero } from '@data/mobileApp';

const { preview } = mobileAppHero;
---

<section
  class="relative overflow-hidden bg-[linear-gradient(160deg,#0d1f14,#14361b)] px-5 pt-[92px] pb-14 lg:px-8 lg:pt-[120px] lg:pb-[72px]"
>
  <div
    class="pointer-events-none absolute -top-24 -left-10 h-[300px] w-[300px] rounded-full bg-[radial-gradient(circle,rgba(43,168,44,0.32),transparent_65%)] lg:h-[460px] lg:w-[460px] lg:-top-[120px] lg:-left-[60px]"
  >
  </div>
  <div
    class="pointer-events-none absolute -bottom-24 right-10 h-[260px] w-[260px] rounded-full bg-[radial-gradient(circle,rgba(243,229,0,0.14),transparent_65%)] lg:-bottom-[160px] lg:h-[400px] lg:w-[400px] lg:right-20"
  >
  </div>

  <div
    class="relative z-[1] mx-auto grid max-w-[1220px] items-center gap-12 lg:grid-cols-[1.1fr_0.9fr] lg:gap-12"
  >
    <div>
      <Button
        href="/"
        variant="link"
        tone="onDark"
        icon="arrowLeft"
        iconPosition="left"
        class="mb-[18px]"
      >
        Volver al inicio
      </Button>
      <div
        class="mb-5 inline-block rounded-full bg-gold-400/22 px-3.5 py-[6px] text-xs font-bold tracking-[0.08em] text-gold-400 uppercase"
      >
        {mobileAppHero.eyebrow}
      </div>
      <h1
        class="mb-[18px] text-[36px] leading-[1.1] font-extrabold tracking-tight text-white sm:text-[44px] lg:text-[52px] lg:leading-[1.05]"
      >
        {
          mobileAppHero.title.split('\n').map((line, i) => (
            <>
              {i > 0 && <br />}
              {line}
            </>
          ))
        }
      </h1>
      <p class="mb-[30px] max-w-[460px] text-lg leading-relaxed text-white/72">
        {mobileAppHero.description}
      </p>
      <div class="flex flex-wrap gap-3.5">
        <StoreBadgeLink
          href={mobileAppHero.appStoreUrl}
          icon="appleLogo"
          iconColor="#0d1f14"
          storeLabel="Descárgala en"
          storeName="App Store"
        />
        <StoreBadgeLink
          href={mobileAppHero.googlePlayUrl}
          icon="googlePlay"
          iconColor="#0d1f14"
          storeLabel="Disponible en"
          storeName="Google Play"
        />
      </div>
    </div>

    <div class="flex justify-center py-4 lg:py-0">
      <!-- Chasis del teléfono: proporción realista ~9:19.5, con animación de
           entrada (fadeup) que continúa en un flotado suave infinito. -->
      <div
        class="relative aspect-[18/39] w-[250px] animate-[fadeup_0.8s_ease_both,floaty_6s_ease-in-out_0.8s_infinite] overflow-hidden rounded-[44px] border-[10px] border-ink-800 bg-ink-950 shadow-[0_40px_90px_rgba(0,0,0,0.5)] transition-shadow duration-300 hover:shadow-[0_52px_110px_rgba(0,0,0,0.6)] sm:w-[290px] sm:rounded-[52px] sm:border-[12px] lg:w-[310px]"
      >
        <div
          class="absolute top-[9px] left-1/2 z-[3] h-[22px] w-[86px] -translate-x-1/2 rounded-full bg-ink-950 sm:top-[11px]"
        >
        </div>

        <div class="flex h-full w-full flex-col bg-[linear-gradient(180deg,#f4fbf5,#fff)]">
          <div
            class="flex items-center justify-between px-6 pt-3.5 text-[11px] font-semibold text-ink-900 sm:pt-[16px]"
          >
            <span>{preview.time}</span>
            <div class="flex items-center gap-2.5">
              <div class="flex items-end gap-[2px]">
                <span class="h-[3px] w-[3px] rounded-[1px] bg-ink-900/70"></span>
                <span class="h-[5px] w-[3px] rounded-[1px] bg-ink-900/70"></span>
                <span class="h-[7px] w-[3px] rounded-[1px] bg-ink-900"></span>
              </div>
              <div class="flex items-center gap-[3px]">
                <div class="h-[10px] w-[18px] rounded-[3px] border border-ink-900/70 p-[1.5px]">
                  <div class="h-full w-full rounded-[1px] bg-ink-900"></div>
                </div>
                <div class="h-[4px] w-[1.5px] rounded-r-[1px] bg-ink-900/70"></div>
              </div>
            </div>
          </div>

          <div class="flex flex-1 flex-col gap-3.5 overflow-hidden px-5 pt-4">
            <div class="flex items-center gap-2.5">
              <Image
                src={logo}
                alt=""
                width={32}
                height={32}
                densities={[1, 2, 3]}
                class="h-8 w-8 rounded-full"
              />
              <div>
                <div class="text-[11px] text-body-200">{preview.greeting}</div>
                <div class="font-display text-[15px] font-extrabold text-ink-900">
                  {preview.userName}
                </div>
              </div>
            </div>

            <div
              class="rounded-[18px] bg-[linear-gradient(135deg,#22a024,#2fb531)] p-[16px] text-white shadow-[0_12px_26px_rgba(43,168,44,0.3)]"
            >
              <div class="text-[11px] opacity-85">{preview.balanceLabel}</div>
              <div class="mt-1 font-display text-2xl font-extrabold">{preview.balanceAmount}</div>
            </div>

            <div class="grid grid-cols-4 gap-1.5">
              {
                preview.quickActions.map((action) => (
                  <div class="flex flex-col items-center gap-1.5">
                    <div class="flex h-10 w-10 items-center justify-center rounded-full bg-brand-600/10">
                      <Icon name={action.icon} size={17} color="#1f8f22" />
                    </div>
                    <span class="text-center text-[8.5px] leading-tight font-semibold text-body-400">
                      {action.label}
                    </span>
                  </div>
                ))
              }
            </div>

            <div class="flex flex-1 flex-col gap-2 overflow-hidden">
              {
                preview.items.map((item) => (
                  <div class="flex items-center gap-2.5 rounded-2xl border border-ink-900/7 bg-white px-3 py-2.5">
                    <div class="h-8 w-8 flex-none rounded-[9px] bg-brand-600/12" />
                    <div class="min-w-0 flex-1">
                      <div class="truncate text-xs font-bold text-ink-900">{item.title}</div>
                      <div class="truncate text-[10px] text-body-200">{item.subtitle}</div>
                    </div>
                    <div class="flex-none text-xs font-bold text-brand-800">{item.trailing}</div>
                  </div>
                ))
              }
            </div>
          </div>

          <div
            class="flex items-center justify-around border-t border-ink-900/6 bg-white/70 py-2.5 backdrop-blur-md"
          >
            {
              preview.navTabs.map((tab, index) => (
                <div
                  class:list={[
                    'flex flex-col items-center gap-1',
                    index === 0 ? 'text-brand-800' : 'text-body-200',
                  ]}
                >
                  <Icon name={tab.icon} size={16} color={index === 0 ? '#1f8f22' : '#9aa89f'} />
                  <span class="text-[8px] font-semibold">{tab.label}</span>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
