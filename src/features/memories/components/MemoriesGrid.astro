---
import MemoryCard from './MemoryCard.astro';
import { memories } from '@data/memories';
---

<section class="px-5 pt-8 pb-24 lg:px-8">
  <div
    class="mx-auto grid max-w-[1120px] grid-cols-1 gap-16 sm:grid-cols-2 lg:grid-cols-3 lg:gap-12"
  >
    {memories.map((memory) => <MemoryCard memory={memory} />)}
  </div>
</section>
