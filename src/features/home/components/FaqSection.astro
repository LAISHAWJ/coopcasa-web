---
import FaqAccordion from '@shared/components/FaqAccordion.astro';
import { faqs } from '@data/faq';
import { faqSection } from '@data/home';
---

<section class="px-5 pt-5 pb-24 lg:px-8">
  <div class="mx-auto max-w-[820px]">
    <div class="mb-12 text-center">
      <div class="mb-3.5 text-[13px] font-bold tracking-[0.1em] text-brand-800 uppercase">{faqSection.eyebrow}</div>
      <h2 class="text-[30px] font-extrabold tracking-tight text-ink-900 sm:text-[38px]">{faqSection.title}</h2>
    </div>
    <FaqAccordion items={faqs} idPrefix="home-faq" />
  </div>
</section>
