---
import Button from '@shared/ui/Button.astro';
import Icon from '@shared/ui/Icon.astro';
import { JOIN_PANEL_MODAL_ID } from '@features/members/constants';
import { hero, quickBenefits } from '@data/hero';
---

<section id="inicio" class="relative overflow-hidden px-5 pt-[104px] pb-14 lg:px-8 lg:pt-[132px] lg:pb-[72px]">
  <div
    class="pointer-events-none absolute -top-40 -right-16 h-[420px] w-[420px] rounded-full bg-[radial-gradient(circle,rgba(43,168,44,0.16),transparent_62%)] blur-[6px] lg:h-[620px] lg:w-[620px] lg:-right-[120px]"
  >
  </div>
  <div
    class="pointer-events-none absolute top-20 -left-24 h-[360px] w-[360px] rounded-full bg-[radial-gradient(circle,rgba(243,229,0,0.22),transparent_62%)] blur-[6px] lg:h-[520px] lg:w-[520px] lg:-left-[180px]"
  >
  </div>

  <div class="relative z-[1] mx-auto grid max-w-[1220px] items-center gap-12 lg:grid-cols-[1.05fr_0.95fr] lg:gap-14">
    <div class="animate-fadeup">
      <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-brand-600/20 bg-brand-600/9 px-3.5 py-[7px] text-[13px] font-semibold text-brand-800">
        <span class="h-[7px] w-[7px] rounded-full bg-brand-600 shadow-[0_0_0_4px_rgba(43,168,44,0.18)]"></span>
        {hero.eyebrow}
      </div>
      <h1 class="mb-[22px] text-[38px] leading-[1.1] font-extrabold tracking-tight text-ink-900 sm:text-[46px] lg:text-[56px] lg:leading-[1.05]">
        {hero.titleLines.map((line) => <>{line}<br /></>)}
        <span class="animate-shimmer bg-[linear-gradient(120deg,#22a024,#5bc93a_40%,#c9c400)] bg-[length:200%_auto] bg-clip-text text-transparent">
          {hero.titleHighlight}
        </span>
      </h1>
      <p class="mb-[34px] max-w-[480px] text-lg leading-relaxed text-body-500">{hero.description}</p>
      <div class="mb-[38px] flex flex-wrap gap-3.5">
        <Button data-modal-open={JOIN_PANEL_MODAL_ID} size="lg" icon="arrowRight">
          {hero.primaryCtaLabel}
        </Button>
        <Button href="/#servicios" variant="outline" size="lg">{hero.secondaryCtaLabel}</Button>
      </div>
      <div class="flex items-center gap-[26px]">
        <div class="flex">
          {hero.avatarColors.map((color) => (
            <div class="-ml-2.5 h-[38px] w-[38px] rounded-full border-[2.5px] border-white" style={{ background: color }}></div>
          ))}
        </div>
        <div>
          <div class="font-display text-base font-extrabold text-ink-900">{hero.membersCountLabel}</div>
          <div class="text-[13px] text-body-200">{hero.membersCountCaption}</div>
        </div>
      </div>
    </div>

    <div class="relative hidden h-[520px] animate-fadeup lg:block">
      <div class="absolute inset-0 overflow-hidden rounded-[28px] shadow-[0_30px_70px_rgba(13,31,20,0.18)]">
        <img src={hero.image.src} alt={hero.image.alt} class="h-full w-full object-cover" />
        <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(34,160,36,0.05),rgba(13,31,20,0.28))]"></div>
      </div>

      <div class="animate-floaty absolute top-[26px] -left-[34px] min-w-[210px] rounded-[20px] border border-white/70 bg-white/72 p-5 shadow-[0_18px_44px_rgba(13,31,20,0.16)] backdrop-blur-lg">
        <div class="mb-1.5 text-xs font-medium text-body-200">{hero.savingsCard.label}</div>
        <div class="font-display text-[26px] font-extrabold tracking-tight text-ink-900">{hero.savingsCard.amount}</div>
        <div class="mt-2 flex items-center gap-1.5 text-xs font-semibold text-brand-800">
          <Icon name="trendUp" size={14} color="#1f8f22" strokeWidth={2.5} />
          {hero.savingsCard.growth}
        </div>
      </div>

      <div class="animate-floaty2 absolute right-[-30px] bottom-[30px] rounded-[20px] border border-white/70 bg-white/72 p-5 shadow-[0_18px_44px_rgba(13,31,20,0.16)] backdrop-blur-lg">
        <div class="mb-3 text-xs font-medium text-body-200">{hero.performanceCard.label}</div>
        <div class="flex h-[60px] items-end gap-2">
          {hero.performanceCard.barHeights.map((height) => (
            <div class="w-3.5 rounded-[5px] bg-[linear-gradient(180deg,#5bc93a,#22a024)]" style={{ height }}></div>
          ))}
        </div>
      </div>

      <div class="animate-floaty absolute bottom-[-18px] left-9 flex items-center gap-[11px] rounded-2xl bg-white p-3 shadow-[0_14px_34px_rgba(13,31,20,0.14)]">
        <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-[linear-gradient(135deg,#f3e500,#ffe94d)]">
          <Icon name="star" size={20} color="#0d1f14" strokeWidth={2.2} />
        </div>
        <div>
          <div class="font-display text-sm font-extrabold text-ink-900">{hero.insuredCard.title}</div>
          <div class="text-[11px] text-body-200">{hero.insuredCard.subtitle}</div>
        </div>
      </div>
    </div>
  </div>

  <div class="relative z-[1] mx-auto mt-10 grid max-w-[1220px] grid-cols-2 gap-4 lg:mt-16 lg:grid-cols-4 lg:gap-[18px]">
    {quickBenefits.map((benefit) => (
      <div class="flex items-center gap-3.5 rounded-2xl border border-ink-900/7 bg-surface-50 px-4 py-[18px] sm:px-5">
        <div class:list={['flex h-11 w-11 flex-none items-center justify-center rounded-xl', benefit.iconBg]}>
          <Icon name={benefit.icon} size={22} color={benefit.iconColor} />
        </div>
        <div>
          <div class="font-display text-[15px] font-bold text-ink-900">{benefit.title}</div>
          <div class="text-[12.5px] leading-tight text-body-200">{benefit.description}</div>
        </div>
      </div>
    ))}
  </div>
</section>
