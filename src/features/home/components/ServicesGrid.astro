---
import Icon from '@shared/ui/Icon.astro';
import { services } from '@data/services';
import { servicesSection } from '@data/home';
import { SERVICE_MODAL_ID } from '../constants';
---

<section id="servicios" class="scroll-mt-20 bg-[linear-gradient(180deg,#fbfdfb,#fff)] px-5 py-[88px] lg:px-8">
  <div class="mx-auto max-w-[1220px]">
    <div class="mx-auto mb-14 max-w-[640px] text-center">
      <div class="mb-3.5 text-[13px] font-bold tracking-[0.1em] text-brand-800 uppercase">{servicesSection.eyebrow}</div>
      <h2 class="mb-4 text-3xl leading-tight font-extrabold tracking-tight text-ink-900 lg:text-[42px]">
        {servicesSection.title.split('\n').map((line, i) => <>{i > 0 && <br />}{line}</>)}
      </h2>
      <p class="text-[17px] leading-relaxed text-body-500">{servicesSection.description}</p>
    </div>

    <div class="grid grid-cols-1 gap-[22px] sm:grid-cols-2 lg:grid-cols-3">
      {services.map((service, index) => (
        <button
          type="button"
          data-modal-open={SERVICE_MODAL_ID}
          data-modal-payload={index}
          class="rounded-[22px] border border-ink-900/8 bg-white p-7 text-left shadow-[0_2px_10px_rgba(13,31,20,0.04)] transition-all duration-300 hover:-translate-y-1.5 hover:border-brand-600/35 hover:shadow-[0_24px_54px_rgba(13,31,20,0.12)]"
        >
          <div class="mb-[22px] flex items-center justify-between">
            <div class:list={['flex h-[54px] w-[54px] items-center justify-center rounded-2xl', service.iconBg]}>
              <Icon name={service.icon} size={26} color={service.iconColor} />
            </div>
            <span class="flex h-[34px] w-[34px] items-center justify-center rounded-full bg-brand-600/8 text-brand-800">
              <Icon name="arrowRight" size={15} />
            </span>
          </div>
          <h3 class="mb-2.5 text-xl font-bold tracking-tight text-ink-900">{service.title}</h3>
          <p class="text-[15px] leading-relaxed text-body-400">{service.description}</p>
        </button>
      ))}
    </div>
  </div>
</section>
