---
import { Image } from 'astro:assets';
import logo from '@assets/images/coopcasa-logo.png';
import Button from '@shared/ui/Button.astro';
import Icon from '@shared/ui/Icon.astro';
import StoreBadgeLink from '@features/mobile-app/components/StoreBadgeLink.astro';
import { appPromo } from '@data/home';
---

<section class="px-5 pt-5 pb-20 lg:px-8">
  <div
    class="relative mx-auto grid max-w-[1220px] items-center gap-8 overflow-hidden rounded-[32px] bg-[linear-gradient(135deg,#0d1f14,#14361b)] px-6 py-12 sm:px-10 lg:grid-cols-[1.2fr_0.8fr] lg:px-14 lg:py-14"
  >
    <div
      class="pointer-events-none absolute -top-[100px] right-[10%] h-[300px] w-[300px] rounded-full bg-[radial-gradient(circle,rgba(43,168,44,0.3),transparent_65%)] lg:right-[180px] lg:h-[360px] lg:w-[360px]"
    >
    </div>
    <div
      class="pointer-events-none absolute -right-10 -bottom-[120px] h-[280px] w-[280px] rounded-full bg-[radial-gradient(circle,rgba(243,229,0,0.14),transparent_65%)] lg:h-[320px] lg:w-[320px]"
    >
    </div>

    <div data-reveal="left" class="relative z-[1]">
      <div
        class="mb-[18px] inline-block rounded-full bg-gold-400/22 px-3.5 py-1.5 text-xs font-bold tracking-[0.08em] text-gold-400 uppercase"
      >
        {appPromo.badge}
      </div>
      <h2
        class="mb-2.5 text-[28px] leading-[1.1] font-extrabold tracking-tight text-white sm:text-[34px]"
      >
        {appPromo.title}
      </h2>
      <p class="mb-3.5 max-w-[420px] text-lg font-semibold text-brand-200">
        {appPromo.subtitle}
      </p>
      <p class="mb-[22px] max-w-[420px] text-base leading-relaxed text-white/72">
        {appPromo.description}
      </p>
      <div class="mb-[26px] flex flex-col gap-2.5">
        {
          appPromo.features.map((feature) => (
            <div class="flex items-center gap-2.5 text-[14.5px] font-medium text-white/90">
              <span class="flex h-7 w-7 flex-none items-center justify-center rounded-full bg-white/10">
                <Icon name={feature.icon} size={14} color="#7ee05a" strokeWidth={2.4} />
              </span>
              {feature.label}
            </div>
          ))
        }
      </div>
      <div class="flex flex-wrap items-center gap-3.5">
        <Button href="/app-movil" variant="inverse" icon="arrowRight">{appPromo.ctaLabel}</Button>
      </div>
      <div class="mt-[22px] flex flex-wrap gap-2.5">
        <StoreBadgeLink
          href={appPromo.appStoreUrl}
          icon="appleLogo"
          iconColor="#0d1f14"
          storeLabel="Descárgala en"
          storeName="App Store"
        />
        <StoreBadgeLink
          href={appPromo.googlePlayUrl}
          icon="googlePlay"
          iconColor="#0d1f14"
          storeLabel="Disponible en"
          storeName="Google Play"
        />
      </div>
    </div>

    <div
      data-reveal="right"
      class="[transition-delay:80ms] relative z-[1] flex justify-center"
    >
      <!-- Chasis del teléfono: misma proporción realista ~9:19.5 y mismo
           lenguaje visual del marco usado en features/mobile-app/AppHero.astro.
           El data-reveal va en este wrapper (no en el chasis) porque el chasis
           ya tiene su propia animación continua (animate-float-phone) sobre
           transform; combinarlas en el mismo elemento haría que la animación
           anule la transición de entrada. -->
      <div
        class="animate-float-phone relative aspect-[18/39] w-[220px] rotate-[-3deg] overflow-hidden rounded-[38px] border-[9px] border-ink-800 bg-ink-950 shadow-[0_30px_70px_rgba(0,0,0,0.45)] sm:w-[250px] sm:rounded-[44px] sm:border-[10px] lg:w-[270px]"
      >
        <div
          class="absolute top-[7px] left-1/2 z-[3] h-5 w-20 -translate-x-1/2 rounded-full bg-ink-950 sm:top-2"
        >
        </div>
        <div class="flex h-full w-full flex-col bg-[linear-gradient(180deg,#f4fbf5,#fff)] px-4 pt-9 pb-5">
          <div class="mb-5 flex items-center gap-2">
            <Image
              src={logo}
              alt=""
              width={28}
              height={28}
              densities={[1, 2, 3]}
              class="h-7 w-7 rounded-full"
            />
            <div class="font-display text-[13px] font-extrabold text-ink-900">
              {appPromo.preview.userName}
            </div>
          </div>
          <div class="rounded-2xl bg-[linear-gradient(135deg,#22a024,#2fb531)] p-4 text-white">
            <div class="text-[10px] opacity-85">{appPromo.preview.balanceLabel}</div>
            <div class="mt-1 font-display text-xl font-extrabold">
              {appPromo.preview.balanceAmount}
            </div>
          </div>
          <div class="mt-4 grid grid-cols-3 gap-1.5">
            {
              appPromo.preview.quickActions.map((action) => (
                <div class="flex flex-col items-center gap-1.5">
                  <div class="flex h-9 w-9 items-center justify-center rounded-full bg-brand-600/10">
                    <Icon name={action.icon} size={16} color="#1f8f22" />
                  </div>
                  <span class="text-center text-[8.5px] leading-tight font-semibold text-body-400">
                    {action.label}
                  </span>
                </div>
              ))
            }
          </div>
          <div class="mt-4 flex flex-1 flex-col justify-end pb-1">
            <div class="flex items-center gap-2.5 rounded-2xl border border-ink-900/7 bg-white px-3 py-2.5 shadow-[0_2px_8px_rgba(13,31,20,0.05)]">
              <div class="flex h-9 w-9 flex-none items-center justify-center rounded-[10px] bg-brand-600/12">
                <Icon name="transfer" size={16} color="#1f8f22" />
              </div>
              <div class="min-w-0 flex-1">
                <div class="truncate text-xs font-bold text-ink-900">
                  {appPromo.preview.transaction.title}
                </div>
                <div class="truncate text-[10px] text-body-200">
                  {appPromo.preview.transaction.subtitle}
                </div>
              </div>
              <div class="flex-none text-xs font-bold text-brand-800">
                {appPromo.preview.transaction.trailing}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
