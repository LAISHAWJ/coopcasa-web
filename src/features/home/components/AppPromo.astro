---
import { Image } from 'astro:assets';
import logo from '@assets/images/coopcasa-logo.png';
import Button from '@shared/ui/Button.astro';
import { appPromo } from '@data/home';
---

<section class="px-5 pt-5 pb-20 lg:px-8">
  <div class="relative mx-auto grid max-w-[1220px] items-center gap-8 overflow-hidden rounded-[32px] bg-[linear-gradient(135deg,#0d1f14,#14361b)] px-6 py-12 sm:px-10 lg:grid-cols-[1.2fr_0.8fr] lg:px-14 lg:py-14">
    <div class="pointer-events-none absolute -top-[100px] right-[10%] h-[300px] w-[300px] rounded-full bg-[radial-gradient(circle,rgba(43,168,44,0.3),transparent_65%)] lg:right-[180px] lg:h-[360px] lg:w-[360px]">
    </div>
    <div class="pointer-events-none absolute -right-10 -bottom-[120px] h-[280px] w-[280px] rounded-full bg-[radial-gradient(circle,rgba(243,229,0,0.14),transparent_65%)] lg:h-[320px] lg:w-[320px]">
    </div>

    <div class="relative z-[1]">
      <div class="mb-[18px] inline-block rounded-full bg-gold-400/22 px-3.5 py-1.5 text-xs font-bold tracking-[0.08em] text-gold-400 uppercase">
        {appPromo.badge}
      </div>
      <h2 class="mb-3.5 text-[28px] leading-[1.1] font-extrabold tracking-tight text-white sm:text-[34px]">{appPromo.title}</h2>
      <p class="mb-[26px] max-w-[420px] text-base leading-relaxed text-white/72">{appPromo.description}</p>
      <Button href="/app-movil" variant="inverse" icon="arrowRight">{appPromo.ctaLabel}</Button>
    </div>

    <div class="relative z-[1] flex justify-center">
      <div class="animate-float-phone relative w-[180px] rotate-[-3deg] overflow-hidden rounded-[34px] border-8 border-ink-800 bg-ink-950 shadow-[0_30px_70px_rgba(0,0,0,0.45)]">
        <div class="absolute top-0 left-1/2 z-[3] h-[18px] w-20 -translate-x-1/2 rounded-b-xl bg-ink-800"></div>
        <div class="bg-[linear-gradient(180deg,#f4fbf5,#fff)] px-3.5 pt-[30px] pb-0">
          <div class="mb-4 flex items-center gap-[7px]">
            <Image src={logo} alt="" width={24} height={24} class="h-6 w-6 rounded-full" />
            <div class="font-display text-xs font-extrabold text-ink-900">{appPromo.preview.userName}</div>
          </div>
          <div class="rounded-2xl bg-[linear-gradient(135deg,#22a024,#2fb531)] p-3.5 text-white">
            <div class="text-[9px] opacity-85">{appPromo.preview.balanceLabel}</div>
            <div class="mt-[3px] font-display text-lg font-extrabold">{appPromo.preview.balanceAmount}</div>
          </div>
          <div class="mt-3 flex flex-col gap-2 pb-4">
            <div class="h-[34px] rounded-[10px] border border-ink-900/7 bg-white"></div>
            <div class="h-[34px] rounded-[10px] border border-ink-900/7 bg-white"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
