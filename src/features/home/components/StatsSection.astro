---
import { stats } from '@data/stats';
import { statsSection } from '@data/home';
import { formatStatValue } from '@shared/utils/formatNumber';
---

<section id="beneficios" class="scroll-mt-20 px-5 pt-10 pb-[88px] lg:px-8">
  <div
    data-stats-root
    class="relative mx-auto max-w-[1220px] overflow-hidden rounded-[32px] bg-[linear-gradient(135deg,#0d1f14,#14361b)] px-6 py-16 sm:px-10 lg:px-14"
  >
    <div
      class="pointer-events-none absolute -top-[100px] -right-[60px] h-[400px] w-[400px] rounded-full bg-[radial-gradient(circle,rgba(43,168,44,0.35),transparent_65%)]"
    >
    </div>
    <div
      class="pointer-events-none absolute -bottom-[120px] -left-10 h-[360px] w-[360px] rounded-full bg-[radial-gradient(circle,rgba(243,229,0,0.16),transparent_65%)]"
    >
    </div>

    <div class="relative z-[1] mx-auto mb-12 max-w-[600px] text-center">
      <h2 class="mb-3.5 text-[28px] font-extrabold tracking-tight text-white sm:text-[38px]">
        {statsSection.title}
      </h2>
      <p class="text-base leading-relaxed text-white/70">{statsSection.description}</p>
    </div>

    <div class="relative z-[1] grid grid-cols-2 gap-4 lg:grid-cols-4 lg:gap-6">
      {
        stats.map((stat) => (
          <div class="rounded-[20px] border border-white/10 bg-white/6 px-5 py-[30px] text-center backdrop-blur-md">
            <div
              data-stat-target={stat.target}
              data-stat-prefix={stat.prefix ?? ''}
              data-stat-suffix={stat.suffix ?? ''}
              data-stat-decimals={stat.decimals ?? 0}
              class="bg-[linear-gradient(120deg,#7ee05a,#f3e500)] bg-clip-text font-display text-[32px] leading-none font-extrabold tracking-tight text-transparent sm:text-[44px]"
            >
              {formatStatValue(0, {
                prefix: stat.prefix,
                suffix: stat.suffix,
                decimals: stat.decimals,
              })}
            </div>
            <div class="mt-2.5 text-sm font-medium text-white/72">{stat.label}</div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  import { initCountUp } from '@shared/utils/countUp';

  document.querySelectorAll<HTMLElement>('[data-stats-root]').forEach((root) => initCountUp(root));
</script>
