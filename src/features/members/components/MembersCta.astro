---
import Button from '@shared/ui/Button.astro';
import { membersCta } from '@data/membersPage';
import { JOIN_PANEL_MODAL_ID } from '../constants';
---

<section class="px-5 pt-5 pb-20 lg:px-8">
  <div class="relative mx-auto max-w-[1220px] overflow-hidden rounded-[32px] bg-[linear-gradient(120deg,#22a024,#2fb531_55%,#8fd626)] px-6 py-16 text-center sm:px-10 lg:px-14">
    <div class="pointer-events-none absolute -top-20 -left-10 h-[320px] w-[320px] rounded-full bg-white/14"></div>
    <div class="pointer-events-none absolute -right-10 -bottom-[120px] h-[380px] w-[380px] rounded-full bg-gold-400/28"></div>

    <div class="relative z-[1] mx-auto max-w-[600px]">
      <h2 class="mb-4 text-[30px] leading-[1.1] font-extrabold tracking-tight text-white sm:text-[44px]">{membersCta.title}</h2>
      <p class="mb-8 text-lg leading-relaxed text-white/92">{membersCta.description}</p>
      <Button data-modal-open={JOIN_PANEL_MODAL_ID} variant="inverse" size="lg" icon="arrowRight">
        {membersCta.ctaLabel}
      </Button>
    </div>
  </div>
</section>
