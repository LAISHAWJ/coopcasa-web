---
import Icon from '@shared/ui/Icon.astro';
import { joinSteps, joinStepsSection } from '@data/benefits';
import { JOIN_PANEL_MODAL_ID } from '../constants';
---

<section class="px-5 py-16 lg:px-8 lg:py-[72px]">
  <div class="mx-auto max-w-[1220px]">
    <div class="mx-auto mb-12 max-w-[600px] text-center lg:mb-[52px]">
      <div class="mb-3.5 text-[13px] font-bold tracking-[0.1em] text-brand-800 uppercase">
        {joinStepsSection.eyebrow}
      </div>
      <h2 class="text-[30px] font-extrabold tracking-tight text-ink-900 sm:text-[38px]">
        {joinStepsSection.title}
      </h2>
    </div>

    <div class="grid grid-cols-1 gap-6 sm:grid-cols-3">
      {
        joinSteps.map((step) => (
          <div class="relative rounded-[22px] border border-ink-900/8 bg-white p-7 shadow-[0_2px_12px_rgba(13,31,20,0.04)]">
            <div class="absolute top-6 right-[26px] font-display text-[56px] leading-none font-extrabold text-brand-600/10">
              {step.number}
            </div>
            <div
              class:list={[
                'mb-[22px] flex h-[52px] w-[52px] items-center justify-center rounded-2xl',
                step.iconBg,
              ]}
            >
              <Icon name={step.icon} size={24} color={step.iconColor} />
            </div>
            <div class="mb-2 text-[13px] font-bold text-brand-800">Paso {step.number}</div>
            <h3 class="mb-2.5 text-xl leading-tight font-bold text-ink-900">{step.title}</h3>
            <p class="mb-[18px] text-[14.5px] leading-relaxed text-body-400">{step.description}</p>
            {step.showFormButton && (
              <button
                type="button"
                data-modal-open={JOIN_PANEL_MODAL_ID}
                class="inline-flex items-center gap-[7px] rounded-xl bg-[linear-gradient(135deg,#22a024,#2fb531)] px-5 py-[11px] font-display text-sm font-bold text-white transition-transform duration-200 hover:-translate-y-0.5"
              >
                Llenar formulario
              </button>
            )}
            {step.minAmountLabel && (
              <div class="inline-flex items-center gap-2 rounded-[11px] bg-gold-400/20 px-[15px] py-2.5 text-[13px] font-bold text-gold-800">
                {step.minAmountLabel}
              </div>
            )}
          </div>
        ))
      }
    </div>
  </div>
</section>
