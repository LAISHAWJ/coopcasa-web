---
import Icon from '@shared/ui/Icon.astro';
import { whyCoopReasons, whyCoopSection } from '@data/benefits';
---

<section class="px-5 py-16 lg:px-8 lg:py-[72px]">
  <div class="mx-auto max-w-[1220px]">
    <div class="mx-auto mb-12 max-w-[620px] text-center lg:mb-[52px]">
      <div class="mb-3.5 text-[13px] font-bold tracking-[0.1em] text-brand-800 uppercase">
        {whyCoopSection.eyebrow}
      </div>
      <h2 class="mb-3.5 text-[28px] font-extrabold tracking-tight text-ink-900 sm:text-[40px]">
        {whyCoopSection.title}
      </h2>
      <p class="text-[17px] leading-relaxed text-body-500">{whyCoopSection.description}</p>
    </div>

    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {
        whyCoopReasons.map((reason) => (
          <div class="rounded-[20px] border border-ink-900/8 bg-white p-6 transition-colors duration-200 hover:border-brand-600/30">
            <div
              class:list={[
                'mb-4 flex h-[46px] w-[46px] items-center justify-center rounded-[13px]',
                reason.iconBg,
              ]}
            >
              <Icon name={reason.icon} size={22} color={reason.iconColor} />
            </div>
            <h3 class="mb-2 text-base font-bold text-ink-900">{reason.title}</h3>
            <p class="text-[13.5px] leading-relaxed text-body-400">{reason.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
