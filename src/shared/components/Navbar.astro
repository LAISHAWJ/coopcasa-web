---
import { Image } from 'astro:assets';
import logo from '@assets/images/coopcasa-logo.png';
import Dropdown from '@shared/ui/Dropdown.astro';
import Button from '@shared/ui/Button.astro';
import Icon from '@shared/ui/Icon.astro';
import Modal from '@shared/ui/Modal.astro';
import { siteConfig } from '@data/siteConfig';
import { homeLink, aboutDropdown, productsDropdown, primaryNavLinks } from '@data/menu';

const MOBILE_NAV_MODAL_ID = 'mobile-nav';
---

<div
  data-navbar
  data-scrolled="false"
  class="fixed inset-x-0 top-0 z-50 border-b border-ink-900/4 bg-white/82 backdrop-blur-[10px] transition-shadow duration-300 data-[scrolled=true]:border-ink-900/5 data-[scrolled=true]:shadow-[0_4px_24px_rgba(13,31,20,0.07)] data-[scrolled=true]:backdrop-blur-md"
>
  <div class="mx-auto flex h-[72px] max-w-[1220px] items-center justify-between gap-6 px-5 lg:px-8">
    <a href={homeLink.href} class="flex items-center gap-[11px]">
      <Image
        src={logo}
        alt={siteConfig.name}
        width={44}
        height={44}
        densities={[1, 2, 3]}
        class="h-11 w-11 rounded-full object-cover shadow-[0_2px_10px_rgba(43,168,44,0.25)]"
      />
      <span class="font-display text-xl font-extrabold tracking-tight">
        <span class="text-brand-800">COOP</span><span class="text-brand-400">CASA</span>
      </span>
    </a>

    <nav class="hidden items-center gap-0.5 lg:flex">
      <a
        href={homeLink.href}
        class="rounded-[10px] px-[13px] py-2 font-display text-[14.5px] font-semibold text-body-600 transition-all duration-200 hover:bg-brand-600/8 hover:text-brand-800"
      >
        {homeLink.label}
      </a>

      <Dropdown label="Conócenos">
        {
          aboutDropdown.map((item) => (
            <a
              href={item.href}
              class="flex items-center gap-[11px] rounded-[11px] px-[13px] py-[11px] font-display text-sm font-semibold text-body-600 transition-all duration-150 hover:bg-brand-600/8 hover:text-brand-800"
            >
              <Icon name={item.icon} size={18} color="#1f8f22" />
              {item.label}
            </a>
          ))
        }
      </Dropdown>

      <Dropdown label="Productos y Servicios">
        {
          productsDropdown.map((item) => (
            <a
              href={item.href}
              class="flex items-center gap-[11px] rounded-[11px] px-[13px] py-[11px] font-display text-sm font-semibold text-body-600 transition-all duration-150 hover:bg-brand-600/8 hover:text-brand-800"
            >
              <Icon name={item.icon} size={18} color="#1f8f22" />
              {item.label}
            </a>
          ))
        }
      </Dropdown>

      {
        primaryNavLinks.map((link) => (
          <a
            href={link.href}
            class="rounded-[10px] px-[13px] py-2 font-display text-[14.5px] font-semibold text-body-600 transition-all duration-200 hover:bg-brand-600/8 hover:text-brand-800"
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2">
      <div class="hidden lg:block">
        <Button href="/oficina-virtual/login" size="sm" icon="loginArrow">
          Iniciar Sesión
        </Button>
      </div>
      <button
        type="button"
        data-modal-open={MOBILE_NAV_MODAL_ID}
        aria-label="Abrir menú"
        class="flex h-11 w-11 items-center justify-center rounded-xl border border-ink-900/10 text-ink-900 lg:hidden"
      >
        <Icon name="menu" size={20} />
      </button>
    </div>
  </div>
</div>

<!-- Menú móvil (no existía en el prototipo desktop-only; ver README, sección "Responsive"). -->
<Modal id={MOBILE_NAV_MODAL_ID} placement="right" panelClass="p-6">
  <div class="mb-6 flex items-center justify-between">
    <span class="font-display text-lg font-extrabold text-ink-900">Menú</span>
    <button
      type="button"
      data-modal-close={MOBILE_NAV_MODAL_ID}
      aria-label="Cerrar menú"
      class="flex h-10 w-10 items-center justify-center rounded-[11px] border border-ink-900/10 text-body-300 transition-colors hover:bg-surface-100"
    >
      <Icon name="close" size={18} />
    </button>
  </div>

  <nav class="flex flex-col gap-1">
    <a
      href={homeLink.href}
      class="rounded-xl px-3 py-3 font-display text-[15px] font-semibold text-body-600 hover:bg-brand-600/8 hover:text-brand-800"
    >
      {homeLink.label}
    </a>

    <p class="mt-3 px-3 text-xs font-bold uppercase tracking-wider text-body-200">Conócenos</p>
    {
      aboutDropdown.map((item) => (
        <a
          href={item.href}
          class="flex items-center gap-3 rounded-xl px-3 py-3 font-display text-[15px] font-semibold text-body-600 hover:bg-brand-600/8 hover:text-brand-800"
        >
          <Icon name={item.icon} size={18} color="#1f8f22" />
          {item.label}
        </a>
      ))
    }

    <p class="mt-3 px-3 text-xs font-bold uppercase tracking-wider text-body-200">
      Productos y Servicios
    </p>
    {
      productsDropdown.map((item) => (
        <a
          href={item.href}
          class="flex items-center gap-3 rounded-xl px-3 py-3 font-display text-[15px] font-semibold text-body-600 hover:bg-brand-600/8 hover:text-brand-800"
        >
          <Icon name={item.icon} size={18} color="#1f8f22" />
          {item.label}
        </a>
      ))
    }

    <div class="mt-3 border-t border-ink-900/8 pt-3">
      {
        primaryNavLinks.map((link) => (
          <a
            href={link.href}
            class="block rounded-xl px-3 py-3 font-display text-[15px] font-semibold text-body-600 hover:bg-brand-600/8 hover:text-brand-800"
          >
            {link.label}
          </a>
        ))
      }
    </div>
  </nav>

  <Button
    href="/oficina-virtual/login"
    size="lg"
    icon="loginArrow"
    class="mt-6 w-full justify-center"
  >
    Iniciar Sesión
  </Button>
</Modal>

<script>
  const nav = document.querySelector<HTMLElement>('[data-navbar]');

  const updateScrolled = () => {
    if (nav) nav.dataset.scrolled = String(window.scrollY > 20);
  };

  window.addEventListener('scroll', updateScrolled, { passive: true });
  updateScrolled();
</script>
