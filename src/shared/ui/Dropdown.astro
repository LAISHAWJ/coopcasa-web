---
import Icon from './Icon.astro';

/**
 * Dropdown de navegación (desktop). Se abre con hover/focus usando únicamente
 * CSS (`group-hover` / `group-focus-within`), replicando el comportamiento
 * del prototipo (onMouseEnter por ítem) sin necesidad de JavaScript.
 */
interface Props {
  label: string;
}

const { label } = Astro.props;
---

<div class="group relative">
  <button
    type="button"
    class="flex items-center gap-[5px] rounded-[10px] px-[13px] py-2 font-display text-[14.5px] font-semibold text-body-600 transition-all duration-200 hover:bg-brand-600/8 hover:text-brand-800"
  >
    {label}
    <Icon
      name="chevronDown"
      size={15}
      class="transition-transform duration-200 group-hover:rotate-180 group-focus-within:rotate-180"
    />
  </button>
  <div
    class="invisible absolute top-[calc(100%+10px)] left-0 z-[60] flex min-w-[250px] -translate-y-1 flex-col gap-0.5 rounded-[18px] border border-ink-900/7 bg-white/90 p-2.5 opacity-0 shadow-[0_20px_50px_rgba(13,31,20,0.14)] backdrop-blur-lg transition-all duration-200 group-hover:visible group-hover:translate-y-0 group-hover:opacity-100 group-focus-within:visible group-focus-within:translate-y-0 group-focus-within:opacity-100"
  >
    <slot />
  </div>
</div>
