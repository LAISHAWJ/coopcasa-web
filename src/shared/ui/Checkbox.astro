---
interface Props {
  id: string;
  name: string;
  required?: boolean;
  /** 'center' para etiquetas de una línea (ej. "Recordarme"), 'start' para texto largo/multilínea. */
  align?: 'center' | 'start';
  error?: string;
  class?: string;
}

const { id, name, required = false, align = 'center', error, class: className } = Astro.props;
---

<div class={className}>
  <label
    for={id}
    class:list={[
      'flex cursor-pointer gap-[11px] text-[13.5px] leading-relaxed text-body-300',
      align === 'center' ? 'items-center' : 'items-start',
    ]}
  >
    <input
      id={id}
      name={name}
      type="checkbox"
      required={required}
      aria-invalid={error ? 'true' : undefined}
      class:list={['h-[18px] w-[18px] flex-none cursor-pointer accent-brand-700', align === 'start' && 'mt-0.5']}
    />
    <span><slot /></span>
  </label>
  {error && (
    <p role="alert" class="mt-1.5 text-xs font-medium text-danger">{error}</p>
  )}
</div>
