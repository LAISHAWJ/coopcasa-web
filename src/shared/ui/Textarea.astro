---
import Label from './Label.astro';
import { fieldClasses, fieldErrorClasses } from './fieldStyles';

interface Props {
  id: string;
  name: string;
  label: string;
  required?: boolean;
  placeholder?: string;
  rows?: number;
  error?: string;
  hint?: string;
  class?: string;
}

const {
  id,
  name,
  label,
  required = false,
  placeholder,
  rows = 5,
  error,
  hint,
  class: className,
  ...rest
} = Astro.props;

const describedBy = error ? `${id}-error` : hint ? `${id}-hint` : undefined;
---

<div class={className}>
  <Label for={id} required={required}>{label}</Label>
  <textarea
    id={id}
    name={name}
    required={required}
    placeholder={placeholder}
    rows={rows}
    aria-invalid={error ? 'true' : undefined}
    aria-describedby={describedBy}
    class:list={[fieldClasses, 'resize-y', error && fieldErrorClasses]}
    {...rest}
  ></textarea>
  {hint && !error && (
    <p id={`${id}-hint`} class="mt-1.5 text-xs text-body-300">{hint}</p>
  )}
  {error && (
    <p id={`${id}-error`} class="mt-1.5 text-xs font-medium text-danger" role="alert">{error}</p>
  )}
</div>
