---
import Label from './Label.astro';
import { fieldClasses, fieldErrorClasses } from './fieldStyles';

interface Props {
  id: string;
  name: string;
  label: string;
  required?: boolean;
  placeholder?: string;
  rows?: number;
  error?: string;
  hint?: string;
  class?: string;
}

const {
  id,
  name,
  label,
  required = false,
  placeholder,
  rows = 5,
  error,
  hint,
  class: className,
  ...rest
} = Astro.props;

const describedBy = [hint ? `${id}-hint` : null, `${id}-error`].filter(Boolean).join(' ');
---

<div class={className}>
  <Label for={id} required={required}>{label}</Label>
  <textarea
    id={id}
    name={name}
    required={required}
    placeholder={placeholder}
    rows={rows}
    aria-invalid={error ? 'true' : 'false'}
    aria-describedby={describedBy}
    data-field={name}
    class:list={[fieldClasses, 'resize-y', error && fieldErrorClasses]}
    {...rest}></textarea>
  {
    hint && (
      <p id={`${id}-hint`} class="mt-1.5 text-xs text-body-300">
        {hint}
      </p>
    )
  }
  <p
    id={`${id}-error`}
    class:list={['mt-1.5 text-xs font-medium text-danger', !error && 'hidden']}
    role="alert"
  >
    {error}
  </p>
</div>
