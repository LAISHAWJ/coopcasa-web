---
interface Props {
  for: string;
  required?: boolean;
  class?: string;
}

const { for: htmlFor, required = false, class: className } = Astro.props;
---

<label
  for={htmlFor}
  class:list={['mb-[7px] block font-display text-[13px] font-semibold text-body-600', className]}
>
  <slot />
  {required && <span class="text-danger" aria-hidden="true"> *</span>}
</label>
